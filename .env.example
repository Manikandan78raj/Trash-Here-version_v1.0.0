# ==========================================
# TRASH HERE - ENVIRONMENT CONFIGURATION
# ==========================================

# Database Configuration (PostgreSQL / Supabase / Render / Railway)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/trash_here?schema=public"

# Server Port & Environment
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# Security & Authentication (JWT & Firebase Auth)
JWT_SECRET="super-secret-trash-here-enterprise-jwt-key-2026"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="super-secret-refresh-trash-here-key-2026"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Firebase Authentication & Cloud Messaging (Simulated in development if empty)
FIREBASE_PROJECT_ID="trash-here-enterprise"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@trash-here-enterprise.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMOCK_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Cloudinary Media Storage (Simulated in development if empty)
CLOUDINARY_CLOUD_NAME="trash-here-cloud"
CLOUDINARY_API_KEY="mock-api-key"
CLOUDINARY_API_SECRET="mock-api-secret"

# Google Maps API (Simulated in development if empty)
GOOGLE_MAPS_API_KEY="mock-google-maps-api-key"

# Stripe Payments (Simulated in development if empty)
STRIPE_SECRET_KEY="sk_test_mock_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_mock_stripe_webhook_secret"

# Frontend URL for CORS
FRONTEND_URL="http://localhost:5173"

# Twilio SMS Provider Configuration (Simulated in development if empty)
TWILIO_ACCOUNT_SID="AC_mock_twilio_account_sid_2026"
TWILIO_AUTH_TOKEN="mock_twilio_auth_token_2026"
TWILIO_PHONE_NUMBER="+15005550006"

# SMTP Email Provider Configuration (Simulated in development if empty)
SMTP_HOST="smtp.mailtrap.io"

# Redis Cache Configuration (Falls back to in-memory cache if false or unreachable)
REDIS_ENABLED="false"
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# PostgreSQL Docker Container Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password123"
POSTGRES_DB="trash_here"
