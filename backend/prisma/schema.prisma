// ============================================================================
// TRASH HERE - ENTERPRISE PRISMA POSTGRESQL SCHEMA
// 19 Production Models for AI-Powered Smart Waste Management Platform
// ============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleType {
  USER
  COLLECTOR
  RECYCLER
  ADMIN
  SUPER_ADMIN
  DISPATCHER
  FINANCE_MANAGER
  SUPPORT_AGENT
}

enum PickupStatus {
  PENDING
  ASSIGNED
  EN_ROUTE
  ARRIVED
  VERIFIED
  COMPLETED
  CANCELLED
}

enum TransactionType {
  PAYOUT
  REWARD_REDEMPTION
  SUBSCRIPTION
  PAYMENT
  BONUS
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIAL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationCategory {
  PICKUP
  PAYMENT
  WALLET
  REWARD
  SUBSCRIPTION
  SECURITY
  SYSTEM
  PROMOTION
}

enum LoadStatus {
  ARRIVED
  WEIGHING_IN
  INSPECTING
  UNLOADING
  WEIGHING_OUT
  ACCEPTED
  REJECTED
  CONTAMINATED
}

enum IntakeSourceType {
  MUNICIPAL
  COMMERCIAL
  COLLECTOR_FLEET
  PUBLIC_DROP_OFF
}

enum InspectionGrade {
  GRADE_A_PURE
  GRADE_B_MINOR_SORT
  GRADE_C_HEAVY_SORT
  REJECTED_HAZARDOUS
}

enum ContaminantType {
  BIOLOGICAL_HAZARD
  NON_RECYCLABLE_PLASTIC
  HEAVY_METALS
  ELECTRONIC_WASTE
  CHEMICAL_RESIDUE
  OIL_GREASE
  GENERAL_DEBRIS
}

enum ContaminantSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ContaminantAction {
  SORTED_OUT
  PENALTY_APPLIED
  LOAD_REJECTED
  QUARANTINED
}

enum BatchStatus {
  RAW_INTAKE
  IN_SORTING
  SHREDDING
  WASHING
  PELLETIZING
  READY_FOR_SALE
  SOLD
}

enum ProcessingStage {
  SORTING
  SHREDDING
  WASHING
  PELLETIZING
  COMPACTING
  BALING
}

enum ProcessingStatus {
  QUEUED
  IN_PROGRESS
  COMPLETED
  HALTED_MAINTENANCE
}

enum EsgComplianceStatus {
  COMPLIANT
  UNDER_REVIEW
  NON_COMPLIANT
}

enum ManifestType {
  INTAKE_RECEIPT
  WEIGHT_CERTIFICATE
  QUALITY_INSPECTION
  ESG_COMPLIANCE_MANIFEST
  TRANSFER_BILL_OF_LADING
}

enum DispatchStatus {
  QUEUED
  OFFERED
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

// 1. Role Model
model Role {
  id          String   @id @default(uuid())
  name        RoleType @unique
  description String?
  permissions String[] // Array of permission scopes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

// 2. User Model
model User {
  id               String           @id @default(uuid())
  email            String           @unique
  phone            String?          @unique
  passwordHash     String?
  fullName         String
  avatarUrl        String?
  roleId           String
  role             Role             @relation(fields: [roleId], references: [id])
  ecoScore         Int              @default(100)
  carbonSavedKg    Float            @default(0.0)
  referralCode     String           @unique @default(uuid())
  referredBy       String?
  isVerified       Boolean          @default(true)
  emailVerifiedAt  DateTime?
  emailVerificationToken String?    @unique
  bio              String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  refreshTokenHash     String?      // SHA-256 hash of active refresh token
  failedLoginAttempts  Int          @default(0)
  lockoutUntil         DateTime?    // Timestamp until which account is locked
  passwordChangedAt    DateTime?    // Invalidate JWTs issued before this date
  mfaSecret            String?      // TOTP secret for enterprise MFA
  mfaEnabled           Boolean      @default(false)
  deviceTokens     String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  addresses        Address[]
  collectorProfile Collector?
  recyclerProfile  RecyclerProfile?
  pickupRequests   PickupRequest[]  @relation("UserPickups")
  transactions     Transaction[]
  wallet           Wallet?
  userRewards      UserReward[]
  notifications    Notification[]
  subscriptions    Subscription[]
  complaints       Complaint[]
  reviews          Review[]         @relation("UserReviews")
  supportTickets   SupportTicket[]
  auditLogs        AuditLog[]
  settings         UserSettings?
  gdprExports      GdprExport[]
  impersonationsPerformed AdminImpersonationLog[] @relation("AdminImpersonations")
  impersonationsReceived  AdminImpersonationLog[] @relation("TargetImpersonations")
  aiUploadedImages        AiImageUpload[]

  @@index([roleId])
}

// 3. Address Model
model Address {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  label            String          @default("Home") // Home, Office, Apartment
  street           String
  city             String
  state            String
  zipCode          String
  country          String          @default("USA")
  lat              Float           @default(37.7749)
  lng              Float           @default(-122.4194)
  isDefault        Boolean         @default(false)
  instructions     String?
  createdAt        DateTime        @default(now())
  pickupRequests   PickupRequest[]

  @@index([userId])
}

// 4. Collector Model
model Collector {
  id               String          @id @default(uuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOnline         Boolean         @default(true)
  isAvailable      Boolean         @default(true)
  rating           Float           @default(5.0)
  totalCompleted   Int             @default(0)
  totalEarnings    Float           @default(0.0)
  currentLat       Float?          @default(37.7749)
  currentLng       Float?          @default(-122.4194)
  serviceRadiusKm  Int             @default(15)
  stripeConnectId  String?         @default("acct_1032D8299381")
  bankAccountLast4 String?         @default("4242")
  instantPayoutsEnabled Boolean    @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  vehicles         Vehicle[]
  assignedPickups  PickupRequest[] @relation("CollectorPickups")
  reviewsReceived  Review[]        @relation("CollectorReviews")
  incomingLoads    IncomingLoad[]  @relation("CollectorLoads")
  dispatchOrders   DispatchOrder[]

  @@index([isOnline, isAvailable])
  @@index([rating])
}

// 5. Vehicle Model
model Vehicle {
  id               String          @id @default(uuid())
  collectorId      String
  collector        Collector       @relation(fields: [collectorId], references: [id], onDelete: Cascade)
  type             String          // Electric Van, Mini Truck, Heavy Loader
  licensePlate     String          @unique
  capacityKg       Float
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([collectorId])
}

// 6. PickupRequest Model
model PickupRequest {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation("UserPickups", fields: [userId], references: [id])
  collectorId      String?
  collector        Collector?      @relation("CollectorPickups", fields: [collectorId], references: [id])
  addressId        String
  address          Address         @relation(fields: [addressId], references: [id])
  status           PickupStatus    @default(PENDING)
  scheduledDate    DateTime
  completedDate    DateTime?
  estimatedWeightKg Float
  actualWeightKg   Float?
  rewardPoints     Int             @default(0)
  estimatedPayout  Float           @default(0.0)
  actualPayout     Float?
  qrCodeSecret     String          @default(uuid())
  aiVerified       Boolean         @default(false)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  items            PickupItem[]
  transactions     Transaction[]
  complaints       Complaint[]
  reviews          Review[]
  dispatchOrders   DispatchOrder[]

  @@index([userId])
  @@index([collectorId])
  @@index([addressId])
  @@index([status])
  @@index([scheduledDate])
}

// 7. PickupItem Model
model PickupItem {
  id               String          @id @default(uuid())
  pickupRequestId  String
  pickupRequest    PickupRequest   @relation(fields: [pickupRequestId], references: [id], onDelete: Cascade)
  categoryId       String
  category         WasteCategory   @relation(fields: [categoryId], references: [id])
  estimatedWeightKg Float
  actualWeightKg   Float?
  aiConfidence     Float?          @default(0.95)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([pickupRequestId])
  @@index([categoryId])
}

// 8. WasteCategory Model
model WasteCategory {
  id               String          @id @default(uuid())
  name             String          @unique
  slug             String          @unique
  description      String
  iconName         String          // Lucide icon name: Cpu, Recycle, Leaf, Trash2, ShieldAlert
  pricePerKg       Float
  pointMultiplier  Int             @default(10)
  isHazardous      Boolean         @default(false)
  co2SavedPerKg    Float           @default(2.5) // kg of CO2 offset per kg recycled
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  pickupItems          PickupItem[]
  materialBatches      MaterialBatch[]
  warehouseInventories WarehouseInventory[]
  aiPredictions        AiPrediction[]
}

// 9. Transaction Model
model Transaction {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  walletId         String?
  wallet           Wallet?           @relation(fields: [walletId], references: [id])
  pickupRequestId  String?
  pickupRequest    PickupRequest?    @relation(fields: [pickupRequestId], references: [id])
  amount           Float
  pointsAmount     Int?              @default(0)
  type             TransactionType
  status           TransactionStatus @default(COMPLETED)
  stripePaymentId  String?
  idempotencyKey   String?           @unique
  description      String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId])
  @@index([walletId])
  @@index([pickupRequestId])
  @@index([type, status])
}

// 10. Reward Model
model Reward {
  id               String          @id @default(uuid())
  title            String
  description      String
  pointsCost       Int
  partnerName      String          // e.g. Starbucks, Airbnb, Patagonia, Whole Foods
  discountValue    String          // e.g. "$15 OFF", "20% Discount", "Free Coffee"
  couponCode       String          @unique
  validUntil       DateTime
  imageUrl         String
  isActive         Boolean         @default(true)
  redeemedCount    Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  userRewards      UserReward[]
}

// 11. Wallet Model
model Wallet {
  id               String          @id @default(uuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsBalance    Int             @default(500) // Signup bonus points
  cashBalance      Float           @default(0.0)
  totalPointsEarned Int            @default(500)
  totalCashEarned  Float           @default(0.0)
  currency         String          @default("USD")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  transactions     Transaction[]
}

// 12. Notification Model
model Notification {
  id               String               @id @default(uuid())
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  message          String
  type             String               @default("INFO") // INFO, PICKUP, REWARD, ALERT
  priority         NotificationPriority @default(NORMAL)
  category         NotificationCategory @default(SYSTEM)
  isRead           Boolean              @default(false)
  linkUrl          String?
  actionUrl        String?
  metadata         Json?
  expirationDate   DateTime?
  scheduledAt      DateTime?
  createdAt        DateTime             @default(now())

  @@index([userId, isRead])
  @@index([category, priority])
}

// 13. Subscription Model
model Subscription {
  id               String             @id @default(uuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planName         String             // "Eco Starter" | "Eco Pro" | "Enterprise Green"
  priceMonthly     Float
  pickupsPerMonth  Int
  status           SubscriptionStatus @default(ACTIVE)
  stripeSubId      String?
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId, status])
}

// 14. Complaint Model
model Complaint {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  pickupRequestId  String?
  pickupRequest    PickupRequest?  @relation(fields: [pickupRequestId], references: [id])
  subject          String
  description      String
  status           ComplaintStatus @default(OPEN)
  resolutionNotes  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([pickupRequestId, status])
}

// 15. Review Model
model Review {
  id               String          @id @default(uuid())
  pickupRequestId  String
  pickupRequest    PickupRequest   @relation(fields: [pickupRequestId], references: [id])
  userId           String
  user             User            @relation("UserReviews", fields: [userId], references: [id])
  collectorId      String
  collector        Collector       @relation("CollectorReviews", fields: [collectorId], references: [id])
  rating           Int             @default(5)
  comment          String?
  createdAt        DateTime        @default(now())

  @@index([collectorId])
  @@index([userId])
  @@index([pickupRequestId])
}

// 16. SupportTicket Model
model SupportTicket {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id])
  category         String          // Billing, Pickup Delay, App Technical, General
  subject          String
  message          String
  priority         TicketPriority  @default(MEDIUM)
  status           ComplaintStatus @default(OPEN)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId, status])
}

// 17. Promotion Model
model Promotion {
  id               String          @id @default(uuid())
  title            String
  subtitle         String
  bannerUrl        String
  targetRole       RoleType        @default(USER)
  validFrom        DateTime        @default(now())
  validTo          DateTime
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
}

// 18. Coupon Model
model Coupon {
  id               String          @id @default(uuid())
  code             String          @unique
  discountPercent  Float
  maxDiscount      Float
  validUntil       DateTime
  usageLimit       Int             @default(100)
  usedCount        Int             @default(0)
  createdAt        DateTime        @default(now())
}

// 19. AuditLog Model
model AuditLog {
  id               String          @id @default(uuid())
  userId           String?
  user             User?           @relation(fields: [userId], references: [id])
  action           String          // LOGIN, CREATE_PICKUP, COMPLETE_JOB, REDEEM_REWARD
  entity           String          // User, PickupRequest, Reward, Wallet
  entityId         String?
  ipAddress        String?         @default("127.0.0.1")
  userAgent        String?
  details          String?
  timestamp        DateTime        @default(now())

  @@index([userId])
  @@index([action, entity])
  @@index([timestamp])
}

// 20. UserReward Model (User redeemed partner vouchers)
model UserReward {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId       String
  reward         Reward    @relation(fields: [rewardId], references: [id])
  redeemedCode   String    @unique // e.g. "SBX-8821-ECO"
  pointsSpent    Int
  status         String    @default("ACTIVE") // ACTIVE, USED, EXPIRED
  redeemedAt     DateTime  @default(now())
  usedAt         DateTime?

  @@index([userId, status])
  @@index([rewardId])
}

// 21. UserSettings Model
model UserSettings {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Notification Preferences
  emailNotifications    Boolean  @default(true)
  smsNotifications      Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  pickupAlerts          Boolean  @default(true)
  rewardAlerts          Boolean  @default(true)
  securityAlerts        Boolean  @default(true)
  marketingAlerts       Boolean  @default(false)
  
  // Privacy Settings
  profileVisibility     String   @default("PUBLIC") // PUBLIC, FRIENDS, PRIVATE
  locationSharing       Boolean  @default(true)
  dataCollectionConsent Boolean  @default(true)
  
  // Security Settings
  twoFactorEnabled      Boolean  @default(false)
  loginAlerts           Boolean  @default(true)
  sessionTimeoutMinutes Int      @default(60)
  
  // Appearance & Locale
  theme                 String   @default("SYSTEM") // LIGHT, DARK, SYSTEM
  language              String   @default("en")
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// 22. GdprExport Model
model GdprExport {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  fileUrl     String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
}

// 23. RecyclerProfile Model (Recycler Facilities)
model RecyclerProfile {
  id                     String               @id @default(uuid())
  userId                 String               @unique
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  facilityName           String
  facilityCode           String               @unique // e.g., "REC-SF-01"
  licenseNumber          String               @unique // e.g., "EPA-CA-99281"
  address                String               // Physical facility location
  capacityDailyTons      Float                @default(50.0)
  operatingHours         String               @default("06:00 - 22:00 MON-SAT")
  contactPhone           String?
  certificationStandards String[]             // ["ISO_14001", "E_STEWARDS", "R2_CERTIFIED"]
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  incomingLoads          IncomingLoad[]
  scaleRecords           ScaleRecord[]
  qualityInspections     QualityInspection[]
  materialBatches        MaterialBatch[]
  warehouseInventories   WarehouseInventory[]
  processingQueue        ProcessingQueue[]
  esgReports             EsgReport[]
  pdfManifests           PdfManifest[]

  @@index([facilityCode])
  @@index([licenseNumber])
}

// 24. IncomingLoad Model (Waste Intake Records)
model IncomingLoad {
  id               String            @id @default(uuid())
  recyclerId       String
  recycler         RecyclerProfile   @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  collectorId      String?
  collector        Collector?        @relation("CollectorLoads", fields: [collectorId], references: [id], onDelete: SetNull)
  truckPlate       String            // License plate of delivery vehicle
  driverName       String
  status           LoadStatus        @default(ARRIVED)
  sourceType       IntakeSourceType  @default(COLLECTOR_FLEET)
  manifestNumber   String            @unique // e.g., "LD-2026-88192"
  scheduledArrival DateTime
  actualArrival    DateTime          @default(now())
  departedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  scaleRecord      ScaleRecord?
  qualityInspection QualityInspection?
  materialBatches  MaterialBatch[]
  pdfManifests     PdfManifest[]
  aiUploadedImages AiImageUpload[]

  @@index([recyclerId, status])
  @@index([collectorId])
  @@index([manifestNumber])
  @@index([actualArrival])
}

// 25. ScaleRecord Model (Digital Scale Weight Verification)
model ScaleRecord {
  id               String          @id @default(uuid())
  loadId           String          @unique
  load             IncomingLoad    @relation(fields: [loadId], references: [id], onDelete: Cascade)
  recyclerId       String
  recycler         RecyclerProfile @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  scaleId          String          @default("SCALE-BRIDGE-01")
  grossWeightKg    Float           // Weight of loaded vehicle
  tareWeightKg     Float           // Weight of empty vehicle after unloading
  netWeightKg      Float           // Calculated waste weight (gross - tare)
  weighInTimestamp DateTime        @default(now())
  weighOutTimestamp DateTime?
  weighmasterName  String
  signatureUrl     String?
  digitalSeal      String          // HMAC SHA-256 cryptographic seal for tamper-proofing
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([recyclerId, weighInTimestamp])
  @@index([scaleId])
}

// 26. QualityInspection Model (Material Purity & Grading)
model QualityInspection {
  id               String            @id @default(uuid())
  loadId           String            @unique
  load             IncomingLoad      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  recyclerId       String
  recycler         RecyclerProfile   @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  inspectorName    String
  overallGrade     InspectionGrade   @default(GRADE_A_PURE)
  moisturePercent  Float             @default(2.5) // % moisture content
  contaminationRate Float            @default(1.2) // % contamination by weight
  notes            String?
  inspectedAt      DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  contaminationFlags ContaminationFlag[]

  @@index([recyclerId, overallGrade])
  @@index([inspectedAt])
}

// 27. ContaminationFlag Model (Contaminant Detection & Penalties)
model ContaminationFlag {
  id                String              @id @default(uuid())
  inspectionId      String
  inspection        QualityInspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  contaminantType   ContaminantType
  severity          ContaminantSeverity @default(MEDIUM)
  estimatedWeightKg Float
  photoUrl          String?
  actionTaken       ContaminantAction   @default(SORTED_OUT)
  createdAt         DateTime            @default(now())

  @@index([inspectionId])
  @@index([contaminantType, severity])
}

// 28. MaterialBatch Model (Sorted Material Lots & Tracking)
model MaterialBatch {
  id               String          @id @default(uuid())
  batchNumber      String          @unique // e.g., "BAT-2026-0707-PET"
  recyclerId       String
  recycler         RecyclerProfile @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  loadId           String?
  load             IncomingLoad?   @relation(fields: [loadId], references: [id], onDelete: SetNull)
  categoryId       String
  category         WasteCategory   @relation(fields: [categoryId], references: [id])
  weightKg         Float
  purityPercent    Float           @default(98.5)
  status           BatchStatus     @default(RAW_INTAKE)
  warehouseLocation String         @default("BAY-A1") // Storage bay or zone
  processedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  processingQueueItems ProcessingQueue[]

  @@index([recyclerId, status])
  @@index([categoryId])
  @@index([batchNumber])
}

// 29. WarehouseInventory Model (Facility Stock & Purity Aggregation)
model WarehouseInventory {
  id                String          @id @default(uuid())
  recyclerId        String
  recycler          RecyclerProfile @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  categoryId        String
  category          WasteCategory   @relation(fields: [categoryId], references: [id])
  totalWeightKg     Float           @default(0.0)
  allocatedWeightKg Float           @default(0.0) // Reserved for active processing or sales orders
  availableWeightKg Float           @default(0.0) // Free stock ready for allocation
  averagePurity     Float           @default(98.0)
  lastAuditedAt     DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([recyclerId, categoryId])
  @@index([recyclerId])
}

// 30. ProcessingQueue Model (Manufacturing & Recycling Operations)
model ProcessingQueue {
  id               String           @id @default(uuid())
  recyclerId       String
  recycler         RecyclerProfile  @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  batchId          String
  batch            MaterialBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  machineId        String           // e.g., "SHREDDER-LINE-01", "WASHING-UNIT-03"
  processStage     ProcessingStage  @default(SORTING)
  status           ProcessingStatus @default(QUEUED)
  inputWeightKg    Float
  outputWeightKg   Float?
  wasteLossKg      Float?           // Material lost during processing (evaporation, residue)
  operatorName     String
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([recyclerId, status])
  @@index([batchId])
  @@index([machineId])
}

// 31. EsgReport Model (Environmental, Social, Governance & Carbon Offsets)
model EsgReport {
  id                    String              @id @default(uuid())
  reportNumber          String              @unique // e.g., "ESG-2026-Q2-REV"
  recyclerId            String
  recycler              RecyclerProfile     @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  reportingPeriod       String              // e.g., "2026-Q2", "2026-ANNUAL"
  startDate             DateTime
  endDate               DateTime
  totalIntakeKg         Float
  totalProcessedKg      Float
  totalRecycledKg       Float
  landfillDiversionRate Float               // e.g., 96.4%
  co2OffsetKg           Float               // Total carbon emissions prevented
  energySavedKwh        Float               // Energy conserved vs virgin material production
  waterSavedLiters      Float               // Water conserved vs virgin material production
  complianceStatus      EsgComplianceStatus @default(COMPLIANT)
  generatedBy           String              @default("SYSTEM_ESG_ENGINE")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  manifests             PdfManifest[]

  @@index([recyclerId, reportingPeriod])
  @@index([complianceStatus])
}

// 32. PdfManifest Model (Tamper-Proof Legal & ESG Documentation)
model PdfManifest {
  id             String          @id @default(uuid())
  manifestNumber String          @unique // e.g., "MAN-2026-88912"
  recyclerId     String
  recycler       RecyclerProfile @relation(fields: [recyclerId], references: [id], onDelete: Cascade)
  loadId         String?
  load           IncomingLoad?   @relation(fields: [loadId], references: [id], onDelete: SetNull)
  esgReportId    String?
  esgReport      EsgReport?      @relation(fields: [esgReportId], references: [id], onDelete: SetNull)
  manifestType   ManifestType    @default(INTAKE_RECEIPT)
  fileUrl        String          // Secure Cloudinary / S3 PDF URL
  fileSizeBytes  Int             @default(245760) // ~240 KB
  sha256Hash     String          // Immutable cryptographic hash of PDF contents
  issuedTo       String          // Entity receiving manifest (e.g., EPA, Municipal Gov, Corporate Partner)
  issuedAt       DateTime        @default(now())
  createdAt      DateTime        @default(now())

  @@index([recyclerId, manifestType])
  @@index([loadId])
  @@index([esgReportId])
  @@index([manifestNumber])
}

// 33. AdminImpersonationLog Model (Secure Admin User Impersonation & Audit)
model AdminImpersonationLog {
  id             String   @id @default(uuid())
  adminId        String
  admin          User     @relation("AdminImpersonations", fields: [adminId], references: [id], onDelete: Cascade)
  targetUserId   String
  targetUser     User     @relation("TargetImpersonations", fields: [targetUserId], references: [id], onDelete: Cascade)
  reason         String   // Mandatory explanation for customer support/audit
  ipAddress      String?  @default("127.0.0.1")
  userAgent      String?
  startedAt      DateTime @default(now())
  endedAt        DateTime?
  
  @@index([adminId])
  @@index([targetUserId])
  @@index([startedAt])
}

// 34. SystemConfig Model (Platform Key-Value Settings & Feature Flags)
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique // e.g., "BASE_PICKUP_FEE_USD", "GREEN_POINT_VALUE_USD", "AUTO_DISPATCH_RADIUS_KM"
  value       String   // Stringified JSON or raw setting value
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([key])
}

// 35. DispatchOrder Model (Live Fleet Dispatch Queue & Algorithm Scoring)
model DispatchOrder {
  id              String         @id @default(uuid())
  pickupRequestId String
  pickupRequest   PickupRequest  @relation(fields: [pickupRequestId], references: [id], onDelete: Cascade)
  collectorId     String?
  collector       Collector?     @relation(fields: [collectorId], references: [id], onDelete: SetNull)
  status          DispatchStatus @default(QUEUED)
  offeredAt       DateTime       @default(now())
  expiresAt       DateTime
  respondedAt     DateTime?
  dispatchScore   Float?         @default(0.0) // Algorithmic score (ETA, distance, collector rating)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([pickupRequestId, status])
  @@index([collectorId, status])
  @@index([expiresAt])
}

// ============================================================================
// SPRINT 10 MARKETING & SEO HUB MODELS
// ============================================================================

enum ContactStatus {
  PENDING
  REVIEWED
  RESPONDED
  SPAM
}

enum JobWorkplaceType {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  SUBMITTED
  REVIEWING
  INTERVIEWING
  OFFERED
  REJECTED
}

// 36. ContactSubmission Model (Public Contact Form Inquiries)
model ContactSubmission {
  id          String        @id @default(uuid())
  name        String
  email       String
  phone       String?
  company     String?
  subject     String
  message     String
  ipAddress   String?       @default("127.0.0.1")
  status      ContactStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([email])
  @@index([status, createdAt])
}

// 37. NewsletterSubscriber Model (Email Marketing & Deduplication)
model NewsletterSubscriber {
  id          String    @id @default(uuid())
  email       String    @unique
  source      String?   @default("landing_footer")
  isActive    Boolean   @default(true)
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email, isActive])
}

// 38. BlogPost Model (Programmatic SEO & Content Hub)
model BlogPost {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  excerpt         String
  content         String
  authorName      String
  authorRole      String
  authorAvatar    String?
  category        String
  coverImage      String?
  readTimeMinutes Int       @default(5)
  isPublished     Boolean   @default(true)
  publishedAt     DateTime  @default(now())
  seoTitle        String?
  seoDescription  String?
  tags            String[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug, isPublished])
  @@index([category])
  @@index([publishedAt])
}

// 39. CareerJob Model (Job Openings & Hiring Postings)
model CareerJob {
  id             String           @id @default(uuid())
  slug           String           @unique
  title          String
  department     String
  location       String
  employmentType String           @default("Full-time") // Full-time, Contract, Intern
  workplaceType  JobWorkplaceType @default(REMOTE)
  salaryRange    String?          // e.g. "$140,000 - $180,000 USD"
  description    String
  requirements   String[]
  isPublished    Boolean          @default(true)
  applications   CareerApplication[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([slug, isPublished])
  @@index([department])
}

// 40. CareerApplication Model (Resume Ingest & Applicant Tracking)
model CareerApplication {
  id           String            @id @default(uuid())
  jobId        String
  job          CareerJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fullName     String
  email        String
  phone        String
  resumeUrl    String
  coverLetter  String?
  linkedinUrl  String?
  portfolioUrl String?
  status       ApplicationStatus @default(SUBMITTED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([jobId, status])
  @@index([email])
}

// 41. SeoMetadata Model (Dynamic Route-Specific SEO Tag Overrides)
model SeoMetadata {
  id             String   @id @default(uuid())
  route          String   @unique // e.g. "/", "/eco-calculator", "/about"
  title          String
  description    String
  canonicalUrl   String?
  ogImage        String?
  ogType         String   @default("website")
  twitterCard    String   @default("summary_large_image")
  keywords       String?
  jsonLdSchema   String?  // Stringified JSON-LD schema
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([route])
}

// 42. PublicAnalyticsEvent Model (Pageview & Telemetry Ingestion)
model PublicAnalyticsEvent {
  id          String   @id @default(uuid())
  eventName   String   // e.g. "PAGE_VIEW", "CALCULATOR_USE", "CTA_CLICK"
  route       String
  visitorId   String?
  sessionId   String?
  referrer    String?
  userAgent   String?
  ipAddress   String?  @default("127.0.0.1")
  metadata    String?  // Stringified JSON metadata
  timestamp   DateTime @default(now())

  @@index([eventName, route])
  @@index([timestamp])
}

// ============================================================================
// SPRINT 11 AI WASTE DETECTION ENGINE MODELS
// ============================================================================

enum AiJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum AiModelType {
  YOLO_V8
  OPENAI_GPT4O_VISION
  GEMINI_1_5_PRO_VISION
  CUSTOM_RESNET
  MOCK_VISION
  HYBRID_VISION
}

enum AiRecommendationType {
  DIRECT_RECYCLE
  REQUIRES_RINSING
  REQUIRES_DISASSEMBLY
  CONTAMINATED_DISPOSE
  HAZARDOUS_SPECIAL_HANDLE
}

// 43. AiModelVersion Model (AI Model Registry & Metadata)
model AiModelVersion {
  id             String      @id @default(uuid())
  versionName    String      @unique // e.g. "yolov8-waste-v2.4", "gpt-4o-2026-05"
  modelType      AiModelType
  description    String?
  isActive       Boolean     @default(true)
  precisionScore Float       @default(0.94) // Mean Average Precision (mAP)
  recallScore    Float       @default(0.91)
  latencyMsAvg   Int         @default(450)
  endpointUrl    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  processingJobs AiProcessingJob[]

  @@index([modelType, isActive])
}

// 44. AiImageUpload Model (Storage Reference & Image Metadata)
model AiImageUpload {
  id             String        @id @default(uuid())
  userId         String?       // User who uploaded (or Collector/Recycler)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  loadId         String?       // Optional link to IncomingLoad (Recycler scale intake)
  load           IncomingLoad? @relation(fields: [loadId], references: [id], onDelete: SetNull)
  fileUrl        String        // S3 / R2 / Cloudinary secure URL
  storageKey     String        @unique // Bucket object key
  fileSizeBytes  Int
  mimeType       String        @default("image/jpeg")
  widthPx        Int?
  heightPx       Int?
  sha256Hash     String        // Tamper-proof cryptographic hash of image bytes
  createdAt      DateTime      @default(now())

  processingJobs AiProcessingJob[]
  predictions    AiPrediction[]

  @@index([userId])
  @@index([loadId])
  @@index([sha256Hash])
}

// 45. AiProcessingJob Model (BullMQ Async Queue & Worker Tracking)
model AiProcessingJob {
  id             String          @id @default(uuid())
  jobId          String          @unique // BullMQ Redis Job ID
  imageId        String
  image          AiImageUpload   @relation(fields: [imageId], references: [id], onDelete: Cascade)
  modelVersionId String?
  modelVersion   AiModelVersion? @relation(fields: [modelVersionId], references: [id], onDelete: SetNull)
  status         AiJobStatus     @default(QUEUED)
  attempts       Int             @default(0)
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  processingMs   Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  predictions    AiPrediction[]

  @@index([status, createdAt])
  @@index([imageId])
  @@index([jobId])
}

// 46. AiPrediction Model (Inference Synthesis & Recommendation)
model AiPrediction {
  id                 String               @id @default(uuid())
  jobId              String
  job                AiProcessingJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  imageId            String
  image              AiImageUpload        @relation(fields: [imageId], references: [id], onDelete: Cascade)
  primaryCategoryId  String?
  primaryCategory    WasteCategory?       @relation(fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  isContaminated           Boolean              @default(false)
  contaminationRate        Float                @default(0.0) // Estimated % contamination
  detectionConfidence      Float                @default(0.0)
  classificationConfidence Float                @default(0.0)
  recommendationConfidence Float                @default(0.0)
  overallConfidence        Float                @default(0.0) // 0.0 to 1.0 confidence score
  providerName             String               @default("mock-vision")
  modelVersion             String               @default("1.0.0")
  processingLatencyMs      Int                  @default(0)
  processingCostUsd        Float?
  recommendationType       AiRecommendationType @default(DIRECT_RECYCLE)
  recommendationText       String               // Actionable recycling instructions
  estimatedWeightKg        Float                @default(0.5)
  co2SavedKg               Float                @default(0.92) // EPA WARM coefficient calculation
  greenPointsEarned        Int                  @default(15)   // Estimated reward points
  rawPayload               String?              // Full JSON response string from AI provider
  createdAt                DateTime             @default(now())

  detectedObjects    AiDetectedObject[]

  @@index([jobId])
  @@index([imageId])
  @@index([primaryCategoryId, isContaminated])
  @@index([overallConfidence])
}

// 47. AiDetectedObject Model (Bounding Box Localization & Object Classification)
model AiDetectedObject {
  id               String        @id @default(uuid())
  predictionId     String
  prediction       AiPrediction  @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  label            String        // e.g. "PET_BOTTLE", "ALUMINUM_CAN", "CARDBOARD_BOX", "HDPE_JUG", "FOOD_WASTE_CONTAMINANT"
  confidenceScore  Float         // 0.0 to 1.0
  xMin             Float         // Bounding box top-left X (normalized 0.0 to 1.0)
  yMin             Float         // Bounding box top-left Y
  xMax             Float         // Bounding box bottom-right X
  yMax             Float         // Bounding box bottom-right Y
  materialType     String        // e.g. "PLASTIC_PET", "METAL_ALUMINUM", "PAPER_CARDBOARD", "ORGANIC"
  isContaminant    Boolean       @default(false)
  createdAt        DateTime      @default(now())

  @@index([predictionId])
  @@index([label, confidenceScore])
  @@index([isContaminant])
}
